# Project-specific keys and credentials. Copy to .env and set values for this project.
# Do not commit .env; it is listed in .gitignore.

# API base URL for this project (e.g. https://your-api.example.com/api/ or http://localhost:4000/api/)
VITE_APP_BASE_URL=

# Optional: base URL for file uploads (e.g. https://your-api.example.com/ or same as API host)
# VITE_APP_FILE_URL=
